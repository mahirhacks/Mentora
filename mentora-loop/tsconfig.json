{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@mentora/shared": ["../shared/src/index.ts"],
      "@client/*": ["../client/src/*"]
    }
  },
  "include": ["src/**/*.ts", "scenarios/**/*.ts"]
}
